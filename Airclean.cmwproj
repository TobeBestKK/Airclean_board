<?xml version="1.0" encoding="utf-8"?>
<Project Version="1.0.0.0">
  <PropertyGroup>
    <OutputName>Airclean</OutputName>
    <OutputDirectory>K:\School\Smart_home_appliances\Airclean_board</OutputDirectory>
    <InterOutputDirectory>K:\School\Smart_home_appliances\Airclean_board\output</InterOutputDirectory>
    <Device>CMS79F723</Device>
    <Config>E7FB,FFEF</Config>
    <Compiler>CMSC</Compiler>
    <Power>0</Power>
  </PropertyGroup>
  <PropertyGroup Condition="'Compiler'=='CMSC'">
    <EnableOptimization>true</EnableOptimization>
    <EnableAssembler>true</EnableAssembler>
    <EnableSpeed>false</EnableSpeed>
    <EnableDebug>false</EnableDebug>
    <EnableInitial>true</EnableInitial>
    <WarningLevel>-9</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Filter>源文件</Filter>
    <Filter>头文件</Filter>
  </ItemGroup>
  <ItemGroup>
    <CompileItem Filter="源文件">main.c</CompileItem>
    <CompileItem Filter="源文件">timer.c</CompileItem>
    <CompileItem Filter="源文件">board.c</CompileItem>
    <CompileItem Filter="源文件">tm1628.c</CompileItem>
    <CompileItem Filter="源文件">tuya_protocol.c</CompileItem>
    <CompileItem Filter="源文件">key.c</CompileItem>
  </ItemGroup>
  <ItemGroup>
    <IncludeItem Filter="头文件">board.h</IncludeItem>
    <IncludeItem Filter="头文件">timer.h</IncludeItem>
    <IncludeItem Filter="头文件">tm1628.h</IncludeItem>
    <IncludeItem Filter="头文件">Touch_Kscan_Library.h</IncludeItem>
    <IncludeItem Filter="头文件">TouchKeyConst.h</IncludeItem>
    <IncludeItem Filter="头文件">tuya_protocol.h</IncludeItem>
    <IncludeItem Filter="头文件">key.h</IncludeItem>
  </ItemGroup>
  <ItemGroup>
    <LibraryItem>CMS_CheckTouch_PT_79F72x_V1.02.lpp</LibraryItem>
  </ItemGroup>
</Project>